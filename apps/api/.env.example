NODE_ENV=production
PORT=3001

# MongoDB Atlas — https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/pulse?retryWrites=true&w=majority

# Upstash Redis — https://console.upstash.com → Create Database → REST URL
REDIS_URL=redis://:<password>@<host>.upstash.io:6379

# Generate with: openssl rand -base64 32
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_INVITE_EXPIRES_IN=72h

# Resend — https://resend.com → API Keys
RESEND_API_KEY=re_
EMAIL_FROM=noreply@yourdomain.com

# Cloudinary — https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe — https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_
# After deploying: Stripe Dashboard → Webhooks → Add endpoint → /billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# Your Vercel deployment URL (no trailing slash)
FRONTEND_URL=https://pulse-learn.vercel.app
